{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "signalkit",
  "version": "0.1.0",
  "identifier": "net.rotko.signalkit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "signalkit",
        "width": 1200,
        "height": 780,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/icon.png"
    ]
  }
}
